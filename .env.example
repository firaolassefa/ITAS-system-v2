# Copy this to .env and fill in your values before deploying

# Database
DB_NAME=itas_db
DB_USER=itas_user
DB_PASSWORD=your_strong_password_here

# JWT Secret (must be at least 32 characters)
JWT_SECRET=your-very-long-secret-key-change-this-in-production

# Frontend API URL (set to your cloud domain)
# Used in frontend build — set this before running docker-compose build
VITE_API_URL=https://your-domain.com/api
